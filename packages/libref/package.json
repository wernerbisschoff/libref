{
  "name": "@wbisschoff13/libref",
  "version": "2.1.0",
  "mcpName": "io.github.wbisschoff13/libref",
  "description": "Local library reference for AI agents. Always current.",
  "keywords": [],
  "homepage": "https://github.com/wbisschoff13/libref",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wbisschoff13/libref.git"
  },
  "bugs": {
    "url": "https://github.com/wbisschoff13/libref/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "type": "module",
  "bin": {
    "libref": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist/",
    "package.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "rimraf --glob dist/** && tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npx biome ci --error-on-warnings",
    "fix": "npx biome check --write",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm run test"
  },
  "publishConfig": {
    "access": "public"
  },
  "author": "wbisschoff13",
  "license": "Apache-2.0",
  "dependencies": {
    "@inquirer/prompts": "^8.2.0",
    "@modelcontextprotocol/sdk": "^1.11.4",
    "commander": "^14.0.0",
    "defuddle": "^0.17.0",
    "ignore": "^7.0.5",
    "linkedom": "^0.18.12",
    "remark-frontmatter": "^5.0.0",
    "remark-parse": "^11.0.0",
    "sql.js-fts5": "^1.4.0",
    "turndown": "^7.2.0",
    "unified": "^11.0.5",
    "yaml": "^2.8.2",
    "zod": "^4.3.6"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.9.1"
  },
  "devDependencies": {
    "@total-typescript/tsconfig": "^1.0.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/mdast": "^4.0.4",
    "@types/node": "^24.9.1",
    "@types/turndown": "^5.0.5",
    "rimraf": "^6.0.1",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^4.0.3"
  },
  "tsx": {
    "require": [
      "tsconfig-paths/register"
    ]
  }
}
